# Copy to .env for local runs. On Render, set these in the dashboard instead.
GEMINI_API_KEY=your_google_gemini_api_key_here

# Optional. Confirm current model ids at https://ai.google.dev
IMAGE_MODEL=gemini-3.1-flash-image
VISION_MODEL=gemini-3.5-flash

# Local only. Render sets PORT for you.
PORT=3000
